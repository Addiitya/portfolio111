<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>_eyeadi Admin — Login</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Outfit:wght@500;700;800&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #050505; color: #f5f5f5; font-family: 'Inter', sans-serif; min-height: 100vh; display: flex; justify-content: center; align-items: center; }
        .login-card { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 3rem; width: 100%; max-width: 400px; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
        .login-card h1 { font-family: 'Outfit', sans-serif; font-size: 1.8rem; margin-bottom: 0.5rem; }
        .login-card p { color: #666; margin-bottom: 2rem; font-size: 0.9rem; }
        .form-group { margin-bottom: 1.2rem; }
        .form-group label { display: block; font-size: 0.8rem; color: #888; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem; }
        .form-group input { width: 100%; padding: 0.9rem 1rem; background: #111; border: 1px solid #222; border-radius: 8px; color: white; font-size: 1rem; outline: none; transition: border-color 0.3s; }
        .form-group input:focus { border-color: #e60000; }
        .btn-login { width: 100%; padding: 1rem; background: #e60000; color: white; border: none; border-radius: 8px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.3s; text-transform: uppercase; letter-spacing: 1px; }
        .btn-login:hover { background: #ff1a1a; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(230,0,0,0.4); }
        .error { background: rgba(230,0,0,0.1); border: 1px solid rgba(230,0,0,0.3); color: #ff6666; padding: 0.8rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; text-align: center; }
        .brand { text-align: center; margin-bottom: 2rem; }
        .brand span { font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 1.2rem; letter-spacing: 2px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand"><span>_EYEADI</span></div>
        <h1>Admin Panel</h1>
        <p>Sign in to manage your portfolio</p>
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        <form method="POST" action="/admin/login">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" required autofocus placeholder="Enter username">
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required placeholder="Enter password">
            </div>
            <button type="submit" class="btn-login">Sign In</button>
        </form>
    </div>
</body>
</html>
