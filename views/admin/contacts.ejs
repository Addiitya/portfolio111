<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>_eyeadi Admin — Contacts</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Outfit:wght@500;700;800&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #050505; color: #f5f5f5; font-family: 'Inter', sans-serif; }
        .admin-nav { display: flex; justify-content: space-between; align-items: center; padding: 1rem 2rem; background: #0a0a0a; border-bottom: 1px solid #151515; position: sticky; top: 0; z-index: 100; }
        .admin-nav .brand { font-family: 'Outfit', sans-serif; font-weight: 800; letter-spacing: 2px; }
        .admin-nav .nav-links { display: flex; gap: 1.5rem; align-items: center; }
        .admin-nav a { color: #888; text-decoration: none; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s; }
        .admin-nav a:hover, .admin-nav a.active { color: #e60000; }
        .admin-nav .logout { color: #555; border: 1px solid #222; padding: 0.4rem 1rem; border-radius: 6px; }
        .admin-nav .logout:hover { border-color: #e60000; color: #e60000; }
        .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
        h1 { font-family: 'Outfit', sans-serif; font-size: 2rem; margin-bottom: 2rem; }
        .message-card { background: #0a0a0a; border: 1px solid #151515; border-radius: 12px; padding: 1.5rem; margin-bottom: 1rem; transition: all 0.3s; }
        .message-card.unread { border-left: 3px solid #e60000; }
        .message-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; }
        .message-header h3 { font-family: 'Outfit', sans-serif; }
        .message-header .date { font-size: 0.8rem; color: #555; }
        .message-meta { display: flex; gap: 1.5rem; margin-bottom: 0.8rem; font-size: 0.85rem; color: #888; }
        .message-body { color: #ccc; line-height: 1.6; padding: 1rem; background: #080808; border-radius: 8px; }
        .btn-mark { background: none; border: 1px solid #333; color: #888; padding: 0.4rem 0.8rem; border-radius: 6px; cursor: pointer; font-size: 0.8rem; transition: all 0.3s; margin-top: 0.8rem; }
        .btn-mark:hover { border-color: #00cc00; color: #00cc00; }
        .btn-whatsapp { background: rgba(37,211,102,0.1); border: 1px solid #25D366; color: #25D366; padding: 0.4rem 0.8rem; border-radius: 6px; cursor: pointer; font-size: 0.8rem; text-decoration: none; display: inline-block; margin-top: 0.8rem; margin-left: 0.5rem; transition: all 0.3s; }
        .btn-whatsapp:hover { background: #25D366; color: #000; }
        .badge { padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600; }
        .badge-red { background: rgba(230,0,0,0.1); color: #e60000; }
        .badge-green { background: rgba(0,200,0,0.1); color: #00cc00; }
        .empty { text-align: center; padding: 4rem; color: #444; }
    </style>
</head>
<body>
    <nav class="admin-nav">
        <div class="brand">_EYEADI ADMIN</div>
        <div class="nav-links">
            <a href="/admin">Dashboard</a>
            <a href="/admin/projects">Projects</a>
            <a href="/admin/contacts" class="active">Contacts</a>
            <a href="/admin/bookings">Bookings</a>
            <a href="/admin/blog">Blog</a>
            <a href="/" target="_blank">View Site</a>
            <a href="/admin/logout" class="logout">Logout</a>
        </div>
    </nav>

    <div class="container">
        <h1>📧 Contact Messages</h1>

        <% if (contacts.length === 0) { %>
            <div class="empty">No messages yet. They'll appear here when visitors submit the contact form.</div>
        <% } %>

        <% contacts.forEach(c => { %>
        <div class="message-card <%= c.read ? '' : 'unread' %>">
            <div class="message-header">
                <h3><%= c.name %> <% if (!c.read) { %><span class="badge badge-red">New</span><% } else { %><span class="badge badge-green">Read</span><% } %></h3>
                <span class="date"><%= new Date(c.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
            </div>
            <div class="message-meta">
                <span>✉ <%= c.email %></span>
                <% if (c.phone) { %><span>📱 <%= c.phone %></span><% } %>
            </div>
            <div class="message-body"><%= c.message %></div>
            <div style="display: flex; align-items: center;">
                <% if (!c.read) { %>
                <form method="POST" action="/admin/contacts/<%= c._id %>/read" style="display:inline;">
                    <button type="submit" class="btn-mark">✓ Mark as Read & Reply via Email</button>
                </form>
                <% } %>
                
                <% if (c.phone) { %>
                    <a href="https://wa.me/<%= c.phone.replace(/[^0-9]/g, '') %>?text=<%= encodeURIComponent('Hi ' + c.name.split(' ')[0] + ', thank you for reaching out to _eyeadi Visuals! We have received your inquiry.') %>" target="_blank" class="btn-whatsapp">💬 Reply via WhatsApp</a>
                <% } %>
            </div>
        </div>
        <% }) %>
    </div>
</body>
</html>
