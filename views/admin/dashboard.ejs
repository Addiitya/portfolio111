<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>_eyeadi Admin</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Outfit:wght@500;700;800&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #050505; color: #f5f5f5; font-family: 'Inter', sans-serif; }
        .admin-nav { display: flex; justify-content: space-between; align-items: center; padding: 1rem 2rem; background: #0a0a0a; border-bottom: 1px solid #151515; position: sticky; top: 0; z-index: 100; }
        .admin-nav .brand { font-family: 'Outfit', sans-serif; font-weight: 800; letter-spacing: 2px; }
        .admin-nav .nav-links { display: flex; gap: 1.5rem; align-items: center; }
        .admin-nav a { color: #888; text-decoration: none; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s; }
        .admin-nav a:hover, .admin-nav a.active { color: #e60000; }
        .admin-nav .logout { color: #555; border: 1px solid #222; padding: 0.4rem 1rem; border-radius: 6px; }
        .admin-nav .logout:hover { border-color: #e60000; color: #e60000; }
        .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
        h1 { font-family: 'Outfit', sans-serif; font-size: 2rem; margin-bottom: 0.5rem; }
        .subtitle { color: #666; margin-bottom: 2rem; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }
        .stat-card { background: #0a0a0a; border: 1px solid #151515; border-radius: 12px; padding: 1.5rem; transition: all 0.3s; cursor: pointer; }
        .stat-card:hover { border-color: #e60000; transform: translateY(-3px); box-shadow: 0 8px 25px rgba(230,0,0,0.1); }
        .stat-card .number { font-family: 'Outfit', sans-serif; font-size: 2.5rem; font-weight: 800; color: #e60000; }
        .stat-card .label { color: #888; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.3rem; }
        .stat-card.alert .number { color: #ff6600; }
        .stat-link { text-decoration: none; color: inherit; }
        .quick-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; }
        .quick-link { display: flex; align-items: center; gap: 1rem; background: #0a0a0a; border: 1px solid #151515; border-radius: 12px; padding: 1.2rem 1.5rem; text-decoration: none; color: white; transition: all 0.3s; }
        .quick-link:hover { border-color: #e60000; background: rgba(230,0,0,0.05); }
        .quick-link .icon { font-size: 1.5rem; }
        .quick-link .info h3 { font-family: 'Outfit', sans-serif; font-size: 1rem; }
        .quick-link .info p { font-size: 0.8rem; color: #666; }
    </style>
</head>
<body>
    <nav class="admin-nav">
        <div class="brand">_EYEADI ADMIN</div>
        <div class="nav-links">
            <a href="/admin" class="active">Dashboard</a>
            <a href="/admin/projects">Projects</a>
            <a href="/admin/contacts">Contacts</a>
            <a href="/admin/bookings">Bookings</a>
            <a href="/admin/blog">Blog</a>
            <a href="/" target="_blank">View Site</a>
            <a href="/admin/logout" class="logout">Logout</a>
        </div>
    </nav>

    <div class="container">
        <h1>Welcome back, <%= username %></h1>
        <p class="subtitle">Here's what's happening with your portfolio.</p>

        <div class="stats-grid">
            <a href="/admin/projects" class="stat-link">
                <div class="stat-card">
                    <div class="number"><%= stats.projectCount %></div>
                    <div class="label">Projects</div>
                </div>
            </a>
            <a href="/admin/contacts" class="stat-link">
                <div class="stat-card <%= stats.unreadContacts > 0 ? 'alert' : '' %>">
                    <div class="number"><%= stats.unreadContacts %></div>
                    <div class="label">Unread Messages</div>
                </div>
            </a>
            <a href="/admin/bookings" class="stat-link">
                <div class="stat-card <%= stats.pendingBookings > 0 ? 'alert' : '' %>">
                    <div class="number"><%= stats.pendingBookings %></div>
                    <div class="label">Pending Bookings</div>
                </div>
            </a>
            <a href="/admin/blog" class="stat-link">
                <div class="stat-card">
                    <div class="number"><%= stats.postCount %></div>
                    <div class="label">Blog Posts</div>
                </div>
            </a>
        </div>

        <h2 style="font-family:'Outfit',sans-serif; margin-bottom:1rem;">Quick Actions</h2>
        <div class="quick-links">
            <a href="/admin/projects" class="quick-link">
                <div class="icon">🎬</div>
                <div class="info"><h3>Manage Projects</h3><p>Add, edit, or remove portfolio items</p></div>
            </a>
            <a href="/admin/contacts" class="quick-link">
                <div class="icon">📧</div>
                <div class="info"><h3>View Messages</h3><p><%= stats.contactCount %> total inquiries</p></div>
            </a>
            <a href="/admin/bookings" class="quick-link">
                <div class="icon">📅</div>
                <div class="info"><h3>Manage Bookings</h3><p><%= stats.bookingCount %> shoot requests</p></div>
            </a>
            <a href="/admin/blog" class="quick-link">
                <div class="icon">✍️</div>
                <div class="info"><h3>Write Blog Post</h3><p>Share behind-the-scenes content</p></div>
            </a>
        </div>
    </div>
</body>
</html>
